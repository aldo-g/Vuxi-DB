generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int           @id @default(autoincrement())
  Name             String?
  email            String        @unique
  passwordHash     String
  createdAt        DateTime      @default(now())
  credits          Int           @default(0)
  projects         Project[]
  redeemedVouchers VoucherCode[]
}

model VoucherCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  credits   Int
  usedById  Int?
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  usedBy    User?     @relation(fields: [usedById], references: [id])
}

model Project {
  id             Int           @id @default(autoincrement())
  userId         Int
  name           String
  baseUrl        String
  orgName        String?
  orgPurpose     String?
  createdAt      DateTime      @default(now())
  industry       String?
  primaryGoal    String?
  targetAudience String?
  analysisRuns   AnalysisRun[]
  user           User          @relation(fields: [userId], references: [id])

  @@unique([userId, baseUrl])
}

model AnalysisRun {
  id            Int            @id @default(autoincrement())
  projectId     Int
  captureJobId  String?
  status        String
  progress      Json?
  finalReport   Json?
  overallScore  Int?
  createdAt     DateTime       @default(now())
  project       Project        @relation(fields: [projectId], references: [id])
  analyzedPages AnalyzedPage[]
}

model AnalyzedPage {
  id          Int          @id @default(autoincrement())
  runId       Int
  url         String
  pageAim     String?
  analysisRun AnalysisRun  @relation(fields: [runId], references: [id])
  screenshots Screenshot[]
}

model CaptureJob {
  id           String   @id
  baseUrl      String
  status       String
  progress     Json?
  urlDiscovery Json?
  results      Json?
  error        String?
  errorType    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AnalysisJob {
  id           String   @id
  captureJobId String
  status       String
  progress     Json?
  analysisData Json?
  results      Json?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Screenshot {
  id             Int          @id @default(autoincrement())
  analyzedPageId Int
  url            String
  filename       String?
  storageUrl     String
  success        Boolean      @default(true)
  viewport       String?
  duration_ms    Int?
  timestamp      DateTime?
  error          String?
  createdAt      DateTime     @default(now())
  analyzedPage   AnalyzedPage @relation(fields: [analyzedPageId], references: [id])
}
