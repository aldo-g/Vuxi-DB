generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int              @id @default(autoincrement())
  Name                String?
  email               String           @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  createdAt           DateTime         @default(now())
  credits             Int              @default(0)
  surveyCompletedAt   DateTime?
  projects            Project[]
  redeemedVouchers    VoucherCode[]
  accounts            Account[]
  sessions            Session[]
  surveyResponse      SurveyResponse?
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VoucherCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  credits   Int
  usedById  Int?
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  usedBy    User?     @relation(fields: [usedById], references: [id])
}

model Project {
  id             Int           @id @default(autoincrement())
  userId         Int
  name           String
  baseUrl        String
  orgName        String?
  orgPurpose     String?
  createdAt      DateTime      @default(now())
  industry       String?
  primaryGoal    String?
  targetAudience String?
  analysisRuns   AnalysisRun[]
  user           User          @relation(fields: [userId], references: [id])

  @@unique([userId, baseUrl])
}

model AnalysisRun {
  id            Int            @id @default(autoincrement())
  projectId     Int
  captureJobId  String?
  status        String
  progress      Json?
  finalReport   Json?
  overallScore  Int?
  createdAt     DateTime       @default(now())
  project       Project        @relation(fields: [projectId], references: [id])
  analyzedPages AnalyzedPage[]
}

model AnalyzedPage {
  id          Int          @id @default(autoincrement())
  runId       Int
  url         String
  pageAim     String?
  analysisRun AnalysisRun  @relation(fields: [runId], references: [id])
  screenshots Screenshot[]
}

model CaptureJob {
  id           String   @id
  baseUrl      String
  status       String
  progress     Json?
  urlDiscovery Json?
  results      Json?
  error        String?
  errorType    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AnalysisJob {
  id           String   @id
  captureJobId String
  status       String
  progress     Json?
  analysisData Json?
  results      Json?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SurveyResponse {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id])
  createdAt             DateTime @default(now())

  // Section 1 — past behaviour
  previousFeedbackMethods  String[]  // multi-select
  feedbackFrequency        String?

  // Section 2 — the report
  surprisedBy              String?   // free text
  actionability            String?
  accuracy                 String?

  // Section 3 — context
  role                     String?
  siteType                 String?

  // Section 4 — mom test + pricing
  alternativeIfGone        String?   // free text
  paidBefore               Boolean?
  paidForWhat              String?   // free text, shown if paidBefore = true
  previousCost             String?   // bracket selection, shown if paidBefore = true

  // Early access
  earlyAccessInterest      String?   // "yes" | "no" | "maybe"
}

model Screenshot {
  id             Int          @id @default(autoincrement())
  analyzedPageId Int
  url            String
  filename       String?
  storageUrl     String
  success        Boolean      @default(true)
  viewport       String?
  duration_ms    Int?
  timestamp      DateTime?
  error          String?
  createdAt      DateTime     @default(now())
  analyzedPage   AnalyzedPage @relation(fields: [analyzedPageId], references: [id])
}
